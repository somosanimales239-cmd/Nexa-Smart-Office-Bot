    "api_contract": "NEXA_AUTOMARKET_APPOINTMENT_RESERVATION_V8",
    "compatibility_api_contract": "NEXA_AUTOMARKET_APPOINTMENT_LEADS_V7",
    "contact_context_contract": "NEXA_APPOINTMENT_CONTACT_CONTEXT_V3",
    "commit_verification_contract": "NEXA_APPOINTMENT_REMOTE_COMMIT_VERIFICATION_V1",
    "agenda_deduplication_contract": "NEXA_AGENDA_REMOTE_RESERVATION_DEDUP_V1",
    "refreshes_dealer_availability_after_create": true,
    "refreshes_dealer_leads_after_create": true,
    "refreshes_agenda_contacts_after_create": true,
    "requires_matching_calendar_appointment": true,
    "requires_complete_lead": true,
    "requires_consumed_availability_slot": true,
    "rejects_lead_only_partial_success": true,
    "verification_retry_does_not_repeat_post": true,

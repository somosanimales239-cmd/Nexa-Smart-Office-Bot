{
  "product": "Nexa Smart Office Bot",
  "update_version": "1.6.0",
  "minimum_base_version": "1.5.0",
  "delivery_type": "complete_source_replacement",
  "openai_required": false,
  "database_migration": "Additive migration 7 adds guarded automatic-action settings, appointment source metadata and the automatic-action audit table. Existing SQLite data, encrypted keys, conversations, appointments, settings, custom knowledge and the 2,880-record automotive library are preserved.",
  "knowledge_library": {
    "name": "Nexa Automotive Dealer Knowledge Library",
    "version": "1.0.0",
    "records": 2880,
    "base_intents": 120,
    "dealer_segments": 12,
    "languages": [
      "en",
      "es"
    ],
    "response_variants": 8640,
    "categories": 9
  },
  "automatic_actions": {
    "default_enabled": false,
    "explicit_user_authorization_required": true,
    "automatic_messages": true,
    "knowledge_first": true,
    "external_ai_fallback_optional": true,
    "dealer_appointment_availability": true,
    "local_calendar_appointments": true,
    "remote_appointment_creation_optional": true,
    "never_changes_customer_records": true,
    "never_deletes_data": true,
    "audit_every_action": true
  },
  "features": [
    "AI Control permission menu with explicit master authorization",
    "guarded automatic customer replies with confidence, delay, language, quiet-hour and rate limits",
    "Knowledge Library first with separately authorized OpenAI or DeepSeek fallback",
    "human review gates for legal, emergency, complaint, refund, payment-dispute and financing-approval conversations",
    "Dealer Appointment Availability read from the dedicated endpoint or authorized reseller availability payload",
    "verified-slot appointment creation in the local Nexa calendar",
    "optional website appointment creation only when the API advertises appointment-create and the user enables it",
    "automatic-action event audit and Emergency pause",
    "hard boundary against automatic customer-record changes",
    "hard boundary against automatic deletion",
    "updated About area and removal of obsolete website-upgrade warning"
  ],

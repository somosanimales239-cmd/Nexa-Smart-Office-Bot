    "durable drafts, outbox and read state",
    "AI Suggestions live conversation mode",
    "website messaging API capability diagnostics"
  ],
  "website_api_requirements": {
    "existing": "messages metadata with messages:read",
    "full_conversation": "message-thread with messages:read",
    "send": "message-send with messages:write",

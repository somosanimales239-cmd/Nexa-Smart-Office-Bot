  "delivery_type": "complete_source_replacement",
  "openai_required": false,
  "database_migration": "Additive migration 8 adds the Messages AI switch and per-thread automatic-reply block state. Existing SQLite data, encrypted keys, conversations, appointments, settings, custom knowledge and the 2,880-record automotive library are preserved.",

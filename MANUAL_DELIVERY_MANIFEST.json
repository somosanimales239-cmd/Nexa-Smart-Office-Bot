    "listing_optional_with_thread_context": true,
    "verifies_reserved_response": true,
    "refreshes_dealer_agenda_after_create": true,
    "response_fields": [
      "lead_id",
      "order_id",
      "appointment_id",
      "source",
      "source_context",
      "thread_id",
      "appointment_status",
      "reserved",
      "reserved_slot_key",

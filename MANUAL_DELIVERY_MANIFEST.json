{
  "product": "Nexa Smart Office Bot",
  "update_version": "1.6.7",
  "minimum_base_version": "1.6.0",
  "delivery_type": "complete_software_source_replacement",
  "website_files_included": false,
  "openai_required": false,
  "database_migration": "No new schema migration. Existing SQLite data, encrypted keys, conversations, appointments, settings, custom knowledge and both built-in Knowledge libraries are preserved.",
  "appointment_communication_library": {
    "contract": "NEXA_BILINGUAL_APPOINTMENT_LIBRARY_V1",
    "version": "1.0.0",
    "locales": [
      "en",
      "es"
    ],
    "phrases": 304,
    "intents": 34,
    "response_templates": 72,
    "topic_lock": true,
    "date_time_preference_memory": true,
    "agenda_ranked_closing": true
  },
  "dealer_availability": {
    "resource": "dealer-appointment-availability",
    "required_scope": "dealer-appointment-availability:read",
    "default_days": 14,
    "optional_filters": [
      "store_id",
      "listing_id"
    ],
    "live_knowledge": true,
    "explicit_verified_slot_selection": true,
    "local_agenda_collision_guard": true,
    "remote_appointment_create_optional": true
  },
  "knowledge_library": {
    "name": "Nexa Automotive Dealer Knowledge Library",
    "version": "1.0.0",
    "records": 2880,
    "base_intents": 120,
    "dealer_segments": 12,
    "languages": [
      "en",
      "es"
    ],
    "response_variants": 8640,
    "categories": 9
  },
  "features": [
    "dedicated English and Spanish appointment communication library",
    "304 natural appointment phrases and 34 contextual intents",
    "72 professional templates filled from live dealer data",
    "appointment topic locking ahead of general automotive Knowledge",
    "requested date and time-band preference memory",
    "same-day and next-day verified alternatives",
    "cross-day exact time-preference match",
    "three-option Agenda-ranked closing strategy",
    "local Agenda conflict filtering before Knowledge recommendations",
    "explicit verified-slot selection before appointment creation",
    "courteous decline with website contact data",
    "guarded two-way chat preserved"
  ],

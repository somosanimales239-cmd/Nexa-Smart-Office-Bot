    "languages": [
      "en",
      "es"
    ],
    "response_variants": 8640,
    "categories": 9
  },
  "message_ai_control": {
    "ai_messages_switch_default_for_upgrade": "mirrors existing automatic-message authorization",
    "ai_messages_switch_default_for_fresh_install": false,
    "independent_from_ai_control": true,
    "per_conversation_auto_reply_block": true,
    "blocked_threads_still_sync_and_analyze": true,
    "manual_reply_remains_available": true,
    "actionable_notifications": true,
    "never_changes_customer_records": true,
    "never_deletes_data": true
  },
  "features": [
    "visible AI Messages ON/OFF switch inside Messages",
    "independent message-interaction gate in addition to AI Control authorization",
    "persistent per-conversation automatic-reply block",
    "blocked conversations continue to synchronize, analyze and notify",
    "manual reply preparation and sending remain available",
    "AI Control and website-send readiness badges",
    "notification navigation to exact conversation or related business area",
    "Windows notification click routing",
    "Nexa Pulse toast click routing",
    "guarded automatic messages and appointments preserved",
    "2,880-record bilingual automotive knowledge library preserved",
    "hard boundary against automatic customer-record changes and deletion"
  ],

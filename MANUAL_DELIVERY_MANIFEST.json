    "name": "Nexa Automotive Dealer Knowledge Library",
    "version": "1.0.0",
    "records": 2880,
    "base_intents": 120,
    "dealer_segments": 12,
    "languages": [
      "en",
      "es"
    ],
    "response_variants": 8640,
    "categories": 9
  },
  "messages_runtime": {
    "messages_ai_master_switch": true,
    "per_thread_automatic_reply_block": true,
    "reading_continues_when_blocked": true,
    "exact_cycle_diagnostics": true,
    "notification_deep_links": true,
    "implicit_learning_on_send": false,
    "never_changes_customer_records": true,
    "never_deletes_data": true
  },
  "features": [
    "visible AI Messages ON/OFF switch in Messages",
    "fixed false Automatic cycle skipped: not ready renderer classification",
    "separate whole-cycle status from per-message skipped and failed counts",
    "exact readiness, reason and website API diagnostics",
    "per-conversation automatic-reply block while synchronization and manual review continue",
    "notification deep links to conversations, appointments, tasks, leads, contacts and connected areas",
    "stale message thread exclusion",
    "guarded automatic replies and verified-slot appointments preserved",
    "2,880-record automotive dealer knowledge library preserved"

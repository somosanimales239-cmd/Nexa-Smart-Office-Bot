{
  "product": "Nexa Smart Office Bot",
  "update_version": "1.6.15",
  "minimum_base_version": "1.6.0",
  "delivery_type": "complete_software_source_replacement",
  "website_files_included": false,
  "openai_required": false,
  "database_migration": "No new schema migration. Existing SQLite data, encrypted keys, conversations, appointments, settings, custom knowledge and both built-in Knowledge libraries are preserved.",
  "appointment_communication_library": {
    "contract": "NEXA_BILINGUAL_APPOINTMENT_LIBRARY_V1",
    "version": "2.0.0",
    "locales": [
      "en",
      "es"
    ],
    "phrases": 371,
    "intents": 40,
    "response_templates": 90,
    "topic_lock": true,
    "date_time_preference_memory": true,
    "agenda_ranked_closing": true,
    "state_contract": "NEXA_BILINGUAL_APPOINTMENT_STATE_LIBRARY_V2",
    "corrected_date_precedence": true,
    "duplicate_time_date_isolation": true,
    "contact_step_state_lock": true
  },
  "dealer_availability": {
    "resource": "dealer-appointment-availability",
    "required_scope": "dealer-appointment-availability:read",
    "default_days": 14,
    "optional_filters": [
      "store_id",
      "listing_id"
    ],
    "live_knowledge": true,
    "explicit_verified_slot_selection": true,
    "local_agenda_collision_guard": true,
    "remote_appointment_create_optional": true
  },
  "dealer_agenda_calendar": {
    "contract": "NEXA_DEALER_AGENDA_CALENDAR_SYNC_V1",
    "resource": "dealer-agenda-calendar",
    "required_scope": "dealer-agenda-calendar:read",
    "appointment_create_resource": "appointment-create",
    "appointment_create_scope": "appointment-create:write",
    "default_days": 14,
    "live_knowledge": true,
    "agenda_visible": true,
    "refresh_after_create": true,
    "website_and_local_collision_guard": true,
    "website_contract": "NEXA_AUTOMARKET_APPOINTMENT_RESERVATION_V8",
    "compatibility_website_contract": "AUTOMARKET_PRO_LEADS_APPOINTMENT_API_V7",
    "refreshes_availability_after_create": true,
    "refreshes_orders_leads_after_create": true,
    "refreshes_agenda_contacts_after_create": true,
    "remote_local_calendar_deduplication": true,
    "dealer_office_shortcuts": true,
    "reserve_appointment_shortcut": true
  },
  "appointment_consistency_guard": {
    "contract": "NEXA_APPOINTMENT_CONSISTENCY_GUARD_V1",
    "contextual_time_contract": "NEXA_CONTEXTUAL_TIME_SELECTION_V1",
    "store_aware_blocked_dates": true,
    "verified_slot_conflict_resolution": true,
    "contextual_am_pm_selection": true,
    "stale_offer_revalidation": true,
    "cross_store_appointment_isolation": true
  },
  "appointment_recovery": {
    "date_context_contract": "NEXA_APPOINTMENT_DATE_CONTEXT_RECOVERY_V1",
    "contact_recovery_contract": "NEXA_APPOINTMENT_CONTACT_RECOVERY_V1",
    "weekday_typo_recovery": true,
    "morning_vs_tomorrow_disambiguation": true,
    "prior_offer_date_memory": true,
    "missing_identity_customer_prompt": true,
    "selected_slot_revalidation": true,
    "customer_facing_failure_reply": true,
    "state_machine_contract": "NEXA_APPOINTMENT_STATE_MACHINE_V2",
    "latest_customer_correction_wins": true,
    "stale_contact_request_invalidation": true,
    "identical_times_scoped_to_active_date": true
  },

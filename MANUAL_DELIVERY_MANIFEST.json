    "languages": [
      "en",
      "es"
    ],
    "response_variants": 8640,
    "categories": 9
  },
  "features": [
    "date-scoped appointment conversation state machine",
    "latest customer date correction precedence",
    "duplicate-time isolation across appointment dates",
    "stale contact-request invalidation after date or time correction",
    "371-phrase bilingual appointment state library",
    "thread-to-Lead appointment creation with customer phone",
    "appointment-create alias discovery",
    "remote Lead reservation verification before customer confirmation",
    "appointment date recovery across calendar refreshes",
    "Spanish weekday typo and morning/tomorrow disambiguation",
    "recoverable appointment customer identity collection",
    "selected-slot revalidation after contact collection",
    "customer-facing appointment failure handling",
    "store-aware Dealer Appointment Agenda availability",
    "verified-slot precedence over contradictory mixed calendar metadata",
    "contextual AM/PM selection from the active conversation",
    "graceful revalidation of previously offered times",
    "V6 Dealer Appointment Agenda discovery and synchronization",
    "safe live calendar cache with stale snapshot replacement",
    "website appointments in Nexa Agenda and Knowledge context",
    "appointment-create write-scope enforcement and V6 request body",
    "immediate dealer calendar refresh after website creation",
    "dedicated English and Spanish appointment communication library",
    "304 natural appointment phrases and 34 contextual intents",
    "72 professional templates filled from live dealer data",
    "appointment topic locking ahead of general automotive Knowledge",
    "requested date and time-band preference memory",
    "same-day and next-day verified alternatives",
    "cross-day exact time-preference match",
    "three-option Agenda-ranked closing strategy",
    "local Agenda conflict filtering before Knowledge recommendations",
    "explicit verified-slot selection before appointment creation",
    "courteous decline with website contact data",
    "guarded two-way chat preserved"
  ],
